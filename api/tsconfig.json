{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["*.ts", "../server/**/*", "../shared/**/*"],
  "exclude": ["node_modules", "../client/**/*", "../**/*.test.ts"]
}
