<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="10dp"
    android:padding="12dp"
    android:background="@drawable/autofill_card_bg"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/autofill_item_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:background="@drawable/autofill_avatar_bg"
        android:textColor="@color/iv_accent_soft"
        android:textSize="15sp"
        android:textStyle="bold"
        android:text="•"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/autofill_item_username"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/iv_text_primary"
        android:singleLine="true"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/autofill_item_avatar"
        app:layout_constraintTop_toTopOf="@id/autofill_item_avatar"
        app:layout_constraintEnd_toStartOf="@id/autofill_item_suggested" />

    <TextView
        android:id="@+id/autofill_item_host"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="13sp"
        android:textColor="@color/iv_text_secondary"
        android:singleLine="true"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@id/autofill_item_username"
        app:layout_constraintEnd_toEndOf="@id/autofill_item_username"
        app:layout_constraintTop_toBottomOf="@id/autofill_item_username" />

    <TextView
        android:id="@+id/autofill_item_suggested"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:background="@drawable/autofill_suggested_chip_bg"
        android:textColor="@color/iv_accent_soft"
        android:textSize="11sp"
        android:textStyle="bold"
        android:text="@string/autofill_suggested"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/autofill_item_chevron"
        app:layout_constraintTop_toTopOf="@id/autofill_item_username"
        android:layout_marginEnd="6dp" />

    <ImageView
        android:id="@+id/autofill_item_chevron"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_autofill_chevron"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
