<?xml version="1.0" encoding="utf-8"?>
<!--
  IronVault Autofill Service configuration.
  - settingsActivity: where the system "Settings" affordance in the
    Autofill provider chooser lands. Points at MainActivity which routes
    to the in-app Settings → Autofill screen.
  - supportsInlineSuggestions: serves chips inline above the keyboard
    on supported IMEs (Gboard etc) on Android 11+.
-->
<autofill-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.ironvault.app.MainActivity"
    android:supportsInlineSuggestions="true" />
