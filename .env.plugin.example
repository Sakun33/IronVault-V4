# ============================================================
# RevenueCat API v2 — Environment Variables Example
# Source: plugin-redoc-0.yaml (RevenueCat Developer API 2.0.0)
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ============================================================


# ------------------------------------------------------------
# REVENUECAT CORE (Required for all API usage)
# ------------------------------------------------------------

# V2 Secret API key — generate at: RevenueCat Dashboard > Project Settings > API Keys > + New (select V2)
REVENUECAT_V2_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your RevenueCat project ID — found in Project Settings
REVENUECAT_PROJECT_ID=proj1ab2c3d4

# Base URL for the RevenueCat REST API v2 (do not change)
REVENUECAT_API_BASE_URL=https://api.revenuecat.com/v2


# ------------------------------------------------------------
# APPLE APP STORE (Required if distributing on iOS/iPadOS/tvOS)
# ------------------------------------------------------------

# iOS/iPadOS app bundle identifier
APPLE_BUNDLE_ID=com.yourcompany.app

# App-specific shared secret (32-char hex) — App Store Connect > Your App > In-App Purchases > App-Specific Shared Secret
APPLE_SHARED_SECRET=1234567890abcdef1234567890abcdef

# In-App Purchase EC private key PEM contents — App Store Connect > Users and Access > Keys > In-App Purchase
APPLE_SUBSCRIPTION_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_CONTENTS_HERE\n-----END EC PRIVATE KEY-----"

# ID of the downloaded In-App Purchase key — shown in App Store Connect when you create/download the key
APPLE_SUBSCRIPTION_KEY_ID=XXXXXXXXXX

# Issuer ID for the In-App Purchase key (UUID) — App Store Connect > Users and Access > Keys (top of page)
APPLE_SUBSCRIPTION_KEY_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# (Optional) App Store Connect API Key PEM contents — for product imports and advanced features
ASC_API_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_ASC_KEY_HERE\n-----END EC PRIVATE KEY-----"

# App Store Connect API Key ID
ASC_API_KEY_ID=XXXXXXXXXX

# App Store Connect API Key Issuer ID (UUID)
ASC_API_KEY_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# (Optional) Vendor number from App Store Connect — required for financial reports
ASC_VENDOR_NUMBER=12345678


# ------------------------------------------------------------
# MAC APP STORE — Legacy (Required only for legacy macOS apps)
# ------------------------------------------------------------

MAC_BUNDLE_ID=com.yourcompany.macapp
MAC_SHARED_SECRET=1234567890abcdef1234567890abcdef


# ------------------------------------------------------------
# GOOGLE PLAY STORE (Required if distributing on Android)
# ------------------------------------------------------------

# Android app package name
GOOGLE_PACKAGE_NAME=com.yourcompany.app
# Note: Also connect a Google Service Account to RevenueCat via the dashboard


# ------------------------------------------------------------
# AMAZON APPSTORE (Required if distributing on Amazon devices)
# ------------------------------------------------------------

AMAZON_PACKAGE_NAME=com.yourcompany.amazonapp

# Amazon Developer Identity Shared Key — Amazon Developer Console > Apps & Services > App Details
AMAZON_SHARED_SECRET=your_amazon_shared_secret_here


# ------------------------------------------------------------
# STRIPE (Required for Stripe-based apps)
# ------------------------------------------------------------

# Stripe connected account ID — must be linked to your RevenueCat account first
# Format: acct_XXXXXXXXXXXXXXXXX
STRIPE_ACCOUNT_ID=acct_xxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# REVENUECAT WEB BILLING / RC BILLING
# ------------------------------------------------------------

RC_BILLING_APP_NAME=Your App Name
RC_BILLING_SUPPORT_EMAIL=support@yourcompany.com
RC_BILLING_DEFAULT_CURRENCY=USD
# Optional: only needed if multiple Stripe accounts are connected
RC_BILLING_STRIPE_ACCOUNT_ID=acct_xxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# ROKU CHANNEL STORE (Required if distributing on Roku)
# ------------------------------------------------------------

# Roku Pay API key (exactly 33 chars) — Roku Developer Dashboard > Roku Pay Web Services
ROKU_API_KEY=your_roku_api_key_exactly_33_chars_

# Roku channel ID (exactly 6 chars) — Roku Developer Dashboard > Channel page
ROKU_CHANNEL_ID=123456

# Roku channel display name (max 30 chars)
ROKU_CHANNEL_NAME=Your Channel Name


# ------------------------------------------------------------
# PADDLE BILLING (Required if using Paddle for payments)
# ------------------------------------------------------------

# Paddle Server-side API key (exactly 50 chars) — Paddle Dashboard > Developer Tools > Authentication
PADDLE_API_KEY=your_paddle_server_side_api_key_here_exactly_50chars

# Use Paddle sandbox environment? (true for testing, false for production)
PADDLE_IS_SANDBOX=false


# ------------------------------------------------------------
# WEBHOOKS (Required if using RevenueCat webhook events)
# ------------------------------------------------------------

# Your server's HTTPS URL to receive RevenueCat subscription events
REVENUECAT_WEBHOOK_URL=https://your-server.com/webhooks/revenuecat

# Optional: secret/auth header value to secure your webhook endpoint
REVENUECAT_WEBHOOK_AUTH_HEADER=your_webhook_secret_here


# ------------------------------------------------------------
# PUBLIC API KEY (Client-side SDK initialization)
# ------------------------------------------------------------

# Public RevenueCat API key — safe to embed in mobile apps
REVENUECAT_PUBLIC_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
