{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd backend && npm install --legacy-peer-deps",
  "framework": null,
  "functions": {
    "backend/server-simple-working.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server-simple-working.ts"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
