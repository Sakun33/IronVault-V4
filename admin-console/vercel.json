{
  "version": 2,
  "buildCommand": "echo 'using pre-built frontend dist'",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'skipping install'",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
