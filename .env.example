# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ironvault
DB_HOST=your-db-host.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# ─── App Server ───────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
ADMIN_PORT=3001
SESSION_SECRET=change-me-in-production-use-random-256-bit-value
JWT_SECRET=change-me-in-production-use-random-256-bit-value
FRONTEND_URL=http://localhost:5001

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── RevenueCat (native billing — iOS and Android) ───────────────────────────
# Get from app.revenuecat.com → Project → API Keys
VITE_REVENUECAT_API_KEY_IOS=appl_your_ios_key_here
VITE_REVENUECAT_API_KEY_ANDROID=goog_your_android_key_here

# ─── Stripe (web billing only) ────────────────────────────────────────────────
# NEVER use Stripe for in-app digital purchases on iOS/Android (violates store guidelines)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Admin Console ────────────────────────────────────────────────────────────
ADMIN_CONSOLE_URL=http://localhost:3001
ADMIN_SECRET_KEY=change-me-in-production

# ─── Capacitor live-reload (dev only, never commit) ──────────────────────────
# CAPACITOR_SERVER_URL=http://192.168.1.x:5001
