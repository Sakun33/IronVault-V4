<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		App Group — must match the group declared on the main App target
		and on the IronVaultWidget target. The extension uses this to read
		the credential blob written by the main app via WidgetBridgePlugin.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.app.ironvault.shared</string>
	</array>

	<!--
		Keychain Sharing — same identifier as the App Group so the
		extension can read items the main app stored in the shared
		keychain access group. Required for future master-password
		fallback support.
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)group.app.ironvault.shared</string>
	</array>

	<!--
		Mark the extension as a credential provider. iOS uses this to
		filter the AutoFill Passwords settings screen.
	-->
	<key>com.apple.developer.authentication-services.autofill-credential-provider</key>
	<true/>
</dict>
</plist>
