{
  "name": "ironvault",
  "version": "1.0.0",
  "description": "IronVault - Secure Password Manager with Intelligent Autofill, Multi-Currency Support, and Complete Dark Mode",
  "type": "module",
  "private": true,
  "main": "server/index.ts",
  "workspaces": [
    "packages/*",
    "admin-console/backend"
  ],
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ios": "MAESTRO_PLATFORM=ios maestro test tests/maestro/",
    "test:e2e:android": "MAESTRO_PLATFORM=android maestro test tests/maestro/",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:build:ios": "npm run build:prod && npx cap copy ios",
    "cap:build:android": "npm run build:prod && npx cap copy android",
    "cap:doctor": "npx cap doctor",
    "admin:start": "ts-node --esm admin-console/backend/server-simple-working.ts",
    "audit:security": "npm audit --audit-level=high",
    "release:ios": "npm run build:prod && npx cap copy ios",
    "release:android": "npm run build:prod && npx cap copy android"
  },
  "keywords": [
    "password-manager",
    "security",
    "encryption",
    "offline",
    "pwa",
    "subscription-manager",
    "bank-statement-analysis",
    "investment-tracking",
    "expense-management",
    "notes",
    "reminders",
    "vault",
    "privacy",
    "zero-knowledge",
    "personal-finance",
    "portfolio-management"
  ],
  "author": "IronVault Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteBookPro/ironvault-app.git"
  },
  "bugs": {
    "url": "https://github.com/ByteBookPro/ironvault-app/issues"
  },
  "homepage": "https://www.ironvault.app",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
